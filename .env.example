# Cement Finance Bot Configuration

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# Optional proxy for Telegram API (when server's network blocks/throttles api.telegram.org)
# Examples:
#   socks5://user:pass@1.2.3.4:1080
#   http://user:pass@1.2.3.4:8080
# Leave empty for direct connection.
BOT_PROXY_URL=

# Network timeouts (seconds)
BOT_REQUEST_TIMEOUT=60
BOT_POLLING_TIMEOUT=30

# Django Database
DB_NAME=db.sqlite3
DB_PATH=../db.sqlite3

# Logging
LOG_LEVEL=INFO
