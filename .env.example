# =====================================================================
# Django server (.env on the Django host)
# =====================================================================

# Shared secret the bot will send in the X-Bot-Token header.
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# The same value must be set as BOT_API_TOKEN on the bot server.
BOT_API_TOKEN=

# =====================================================================
# Bot server (.env on the bot host)
# =====================================================================

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# Django API base URL (no trailing slash) and the shared secret above.
DJANGO_API_URL=https://your-django-host.example.com
BOT_API_TOKEN=

# Optional proxy for Telegram API (when server's network blocks/throttles api.telegram.org)
# Examples:
#   socks5://user:pass@1.2.3.4:1080
#   http://user:pass@1.2.3.4:8080
# Leave empty for direct connection.
BOT_PROXY_URL=

# Network timeouts (seconds)
BOT_REQUEST_TIMEOUT=60
BOT_POLLING_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
